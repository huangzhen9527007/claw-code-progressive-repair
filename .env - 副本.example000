# Claude Code 环境变量配置示例
# 复制此文件为 .env 并修改相应的值

# ============================================
# 基础认证配置
# ============================================

# Anthropic API密钥（直接API访问）
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic OAuth认证令牌
ANTHROPIC_AUTH_TOKEN=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API基础URL
# 默认：https://api.anthropic.com
# 示例：https://api.deepseek.com/anthropic（用于DeepSeek等兼容服务）
ANTHROPIC_BASE_URL=https://api.anthropic.com

# 默认模型名称
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# 小快速模型（用于特定场景如工具调用）
ANTHROPIC_SMALL_FAST_MODEL=claude-3-5-haiku-20241022

# ============================================
# 上下文窗口配置
# ============================================

# 最大上下文token数（影响所有API提供商）
# 默认值：102400
CLAUDE_CODE_MAX_CONTEXT_TOKENS=102400

# 自动压缩窗口阈值
# 当上下文使用超过此值时触发自动压缩
# 默认值：102400
CLAUDE_CODE_AUTO_COMPACT_WINDOW=102400

# 禁用1M上下文（HIPAA合规性）
# 设置为 true 时禁用1M上下文支持
# CLAUDE_CODE_DISABLE_1M_CONTEXT=false

# ============================================
# 输出token配置
# ============================================

# 全局最大输出token数（影响所有API提供商）
# 默认值：根据模型自动计算
CLAUDE_CODE_MAX_OUTPUT_TOKENS=8192

# OpenAI兼容API特定的最大输出token数（优先级最高）
# 仅影响OpenAI兼容API，不影响其他API提供商
# 默认值：8192
CLAUDE_CODE_MAX_OUTPUT_TOKENS_OPENAI=8192

# ============================================
# OpenAI兼容API配置
# ============================================

# 启用OpenAI兼容API
# 设置为 true 时使用OpenAI兼容API而不是Anthropic API
CLAUDE_CODE_USE_OPENAI_COMPAT=true

# OpenAI兼容API基础URL
# 示例：http://localhost:11434 或 https://api.openai.com/v1
OPENAI_COMPAT_BASE_URL=http://localhost:11434

# OpenAI兼容API密钥
# 如果API需要认证，请设置此值
OPENAI_COMPAT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI兼容API模型名称
# 示例：deepseek-chat, gpt-4, qwen-plus 等
OPENAI_COMPAT_MODEL=deepseek-chat

# ============================================
# 其他API提供商配置
# ============================================

# 启用AWS Bedrock API
# CLAUDE_CODE_USE_BEDROCK=false

# 启用Google Vertex AI API
# CLAUDE_CODE_USE_VERTEX=false

# 启用Microsoft Foundry API
# CLAUDE_CODE_USE_FOUNDRY=false

# ============================================
# 超时和性能配置
# ============================================

# API请求超时时间（毫秒）
# 默认值：600000（10分钟）
API_TIMEOUT_MS=600000

# 禁用非必要流量（隐私模式）
# 设置为 true 时禁用分析、遥测等非必要流量
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=false

# ============================================
# 功能标志
# ============================================

# 禁用思考功能
# CLAUDE_CODE_DISABLE_THINKING=false

# 简化输出模式
# CLAUDE_CODE_STREAMLINED_OUTPUT=false

# 裸模式（跳过hooks、LSP、插件同步等）
# CLAUDE_CODE_SIMPLE=false

# ============================================
# 性能调优
# ============================================

# 维护项目工作目录
# CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR=false

# ============================================
# 调试和日志
# ============================================

# 调试日志级别
# DEBUG=*

# ============================================
# 授权和发布控制
# ============================================

# 授权标志（用于启动和发布控制）
# 设置为任意非零值（如 true、1、yes 等）以启用授权功能
# AUTHORIZED=true

# ============================================
# 授权和发布控制
# ============================================

# 授权标志（用于启动和发布控制）
# 设置为任意非零值（如 true、1、yes 等）以启用授权功能
# AUTHORIZED=true

# ============================================
# 使用示例
# ============================================

# 示例1：使用DeepSeek作为OpenAI兼容API
# CLAUDE_CODE_USE_OPENAI_COMPAT=true
# OPENAI_COMPAT_BASE_URL=https://api.deepseek.com
# OPENAI_COMPAT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_COMPAT_MODEL=deepseek-chat

# 示例2：使用本地Ollama
# CLAUDE_CODE_USE_OPENAI_COMPAT=true
# OPENAI_COMPAT_BASE_URL=http://localhost:11434
# OPENAI_COMPAT_API_KEY=ollama
# OPENAI_COMPAT_MODEL=llama3.2

# 示例3：使用Anthropic官方API
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ============================================
# 注意：
# 1. 以 # 开头的行是注释，不会被加载
# 2. 取消注释并设置值以启用相应的功能
# 3. 环境变量名称区分大小写
# 4. 优先级：命令行参数 > .env文件 > 系统环境变量 > 默认值
# 5. 对于OpenAI兼容API，CLAUDE_CODE_USE_OPENAI_COMPAT必须设置为true
# ============================================